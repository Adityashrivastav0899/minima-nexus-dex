body {
  margin: 0;
  font-family: Arial, Helvetica, sans-serif;
  background: #05070d;
  color: white;
}

/* Background glow */
body::before {
  content: "";
  position: fixed;
  inset: 0;
  z-index: -1;
  background:
    radial-gradient(circle at top left, rgba(0,255,190,0.18), transparent 35%),
    radial-gradient(circle at bottom right, rgba(0,145,255,0.16), transparent 35%);
}

/* Navbar */
.nav {
  max-width: 1100px;
  margin: auto;
  padding: 22px 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.nav h1 {
  margin: 0;
}

.nav p {
  margin: 5px 0 0;
  color: #aab3c2;
}

/* Main container */
main {
  max-width: 1100px;
  margin: auto;
  padding: 16px;
}

/* Cards */
.card {
  background: rgba(14, 17, 25, 0.9);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 20px;
  padding: 20px;
  margin-bottom: 18px;
  box-shadow: 0 15px 50px rgba(0,0,0,0.4);
}

/* Hero */
.hero h2 {
  font-size: 40px;
  margin-bottom: 10px;
}

.hero p {
  color: #b7c0ce;
  line-height: 1.6;
}

/* Grid layout */
.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18px;
}

/* Buttons */
button {
  border: none;
  border-radius: 12px;
  padding: 10px 14px;
  margin: 5px 0;
  font-weight: bold;
  cursor: pointer;
  background: linear-gradient(135deg, #00d99a, #00a3ff);
  color: #00120d;
}

button:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

/* Inputs */
input, select {
  width: 100%;
  padding: 10px;
  margin: 8px 0 12px;
  border-radius: 10px;
  border: 1px solid rgba(255,255,255,0.2);
  background: #070a10;
  color: #d7ffe8;
}

/* Code + output */
code {
  display: block;
  background: #070a10;
  padding: 10px;
  border-radius: 10px;
  overflow: auto;
}

pre {
  background: #070a10;
  padding: 10px;
  border-radius: 10px;
  min-height: 100px;
  overflow: auto;
  white-space: pre-wrap;
}

/* Labels */
label {
  font-weight: bold;
  color: #cbd5e1;
}

/* Status box */
.status {
  margin-top: 10px;
  padding: 10px;
  border-radius: 10px;
  background: rgba(255,255,255,0.08);
}

/* Notes */
.note {
  margin-top: 10px;
  padding: 10px;
  background: rgba(255,170,0,0.1);
  border-radius: 10px;
  color: #ffcc75;
}

/* Tables */
table {
  width: 100%;
  border-collapse: collapse;
}

th, td {
  padding: 10px;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  text-align: left;
}

th {
  color: #9ca3af;
}

/* Footer */
footer {
  text-align: center;
  color: #8b95a5;
  padding: 25px;
}

/* Mobile responsive */
@media (max-width: 800px) {
  .grid {
    grid-template-columns: 1fr;
  }

  .nav {
    flex-direction: column;
    align-items: flex-start;
  }
}
